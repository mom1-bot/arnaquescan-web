# Server-side only (no VITE_ prefix — never bundled to the client).
# Used by api/analyze.ts, the shared proxy for the mobile app and this site.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Redis store (Vercel Marketplace > Upstash for Redis) — used by api/analyze.ts
# to rate-limit anonymous (non-logged-in) analysis requests.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# Firebase Admin service-account credentials (full JSON as one line) — used by
# api/analyze.ts (trial/quota enforcement), api/revenuecat-webhook.ts and
# api/subscription-sync.ts to read/write Firestore and look up Auth users.
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# RevenueCat SECRET key (different from the mobile app's public SDK key) —
# used by api/subscription-sync.ts to call RevenueCat's REST API server-side.
# RevenueCat dashboard > Project settings > API keys > Secret keys.
REVENUECAT_SECRET_KEY=sk_...

# Shared secret sent as the "Authorization" header by RevenueCat webhooks —
# set the same value in RevenueCat dashboard > Project settings > Webhooks.
# Generate with e.g. `openssl rand -hex 32`.
REVENUECAT_WEBHOOK_SECRET=...
