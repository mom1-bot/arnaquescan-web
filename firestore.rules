// Mirrors the Firestore security rules deployed to the "arnaquescan" Firebase
// project (Console > Firestore Database > Rules). Kept here for review and
// history — there is no automated deploy wired up from this file yet, so any
// change made here must also be pushed to Firebase (Console, or the
// firebaserules.googleapis.com API) to take effect.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Any authenticated user can read all reports (community feed)
      allow read: if request.auth != null;

      // Only authenticated users can create a report
      // — userId must match the caller's uid
      // — all required fields must be present with correct types
      // — date must be the server timestamp (prevents backdating)
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.score   is number
                    && request.resource.data.score   >= 0
                    && request.resource.data.score   <= 100
                    && request.resource.data.niveau  is string
                    && request.resource.data.verdict is string
                    && request.resource.data['résumé'] is string
                    && request.resource.data.date    == request.time;

      // Users can delete only their own reports
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Updates are never allowed — reports are immutable
      allow update: if false;
    }

    match /analyses/{analysisId} {
      // Private per-user analysis history for ArnaqueScanWeb's /historique
      // (src/utils/firestoreHistory.ts) — unlike /reports, this is NOT a
      // public feed. Only the owner may read, create or delete their own
      // entries; entries are immutable once created.
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId    == request.auth.uid
                    && request.resource.data.score      is number
                    && request.resource.data.score      >= 0
                    && request.resource.data.score      <= 100
                    && request.resource.data.niveau     is string
                    && request.resource.data.verdict    is string
                    && request.resource.data['résumé']  is string
                    && request.resource.data.createdAt  == request.time;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    match /users/{uid} {
      // Quota + premium status is enforced server-side only (Admin SDK, from
      // ArnaqueScanWeb's api/analyze.ts + api/revenuecat-webhook.ts +
      // api/subscription-sync.ts). The client may only read its own doc, to
      // display remaining quota / premium state — never write it directly.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
